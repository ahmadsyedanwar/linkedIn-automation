# Port for the API server (default: 9000)
PORT=9000

# Bearer token to authenticate API requests.
# Leave empty to run open/unauthenticated (dev only).
LINKEDIN_API_TOKEN=your-secret-token-here

# Webhook URL to POST a JSON payload to after each scrape run.
# Used by OpenClaw or Claude remote triggers.
# Leave empty to disable.
LINKEDIN_WEBHOOK_URL=http://localhost:18789/webhook/linkedin

# --- Browser and files (optional; Linux snap defaults are built in) ---
# Path to Chrome or Chromium. On Windows, e.g.:
# LINKEDIN_CHROME_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe
# LINKEDIN_CHROME_EXECUTABLE=

# User data root (parent of "Default" / "Profile 1" folders). On Windows, e.g.:
# LINKEDIN_CHROME_USER_DATA=%LOCALAPPDATA%\Google\Chrome\User Data
# LINKEDIN_CHROME_USER_DATA=

# Temp copies of Chrome profiles (inbox scraper). Default: <system temp>/linkedin_pw
# LINKEDIN_TMP_PROFILE_BASE=

# Inbox/mentions JSON, status, logs. Default: system temp directory.
# LINKEDIN_OUTPUT_DIR=
# LINKEDIN_LOG_FILE=
