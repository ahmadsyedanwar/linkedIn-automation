# Port for the API server (default: 9000)
PORT=9000

# Bearer token to authenticate API requests.
# Leave empty to run open/unauthenticated (dev only).
LINKEDIN_API_TOKEN=your-secret-token-here

# Webhook URL to POST a JSON payload to after each scrape run.
# Used by OpenClaw or Claude remote triggers.
# Leave empty to disable.
LINKEDIN_WEBHOOK_URL=http://localhost:18789/webhook/linkedin
